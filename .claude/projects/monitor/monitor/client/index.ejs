<div class="filter-bar">
  <input type="text" id="search" placeholder="搜索会话..." oninput="loadList()">
  <input type="date" id="dateFrom" onchange="loadList()">
  <span>—</span>
  <input type="date" id="dateTo" onchange="loadList()">
  <span style="font-size:13px;color:#888;"><span id="totalCount">0</span> 个会话</span>
</div>

<table>
  <thead>
    <tr>
      <th>会话</th>
      <th>模型</th>
      <th>消息</th>
      <th>缓存 / 未缓存</th>
      <th>输出</th>
      <th>单次峰值</th>
      <th>花费 (¥)</th>
      <th>节省 (¥)</th>
      <th>Agent</th>
      <th>技能</th>
      <th>用户消息预览</th>
      <th>时间</th>
    </tr>
  </thead>
  <tbody id="convBody"></tbody>
</table>

<div class="pagination" id="pagination"></div>

<script>
let page = 1;
async function loadList() {
  const search = document.getElementById('search').value;
  const dateFrom = document.getElementById('dateFrom').value;
  const dateTo = document.getElementById('dateTo').value;
  const params = new URLSearchParams({ page, limit: 20, search, date_from: dateFrom, date_to: dateTo });
  const res = await fetch('/api/conversations?' + params);
  const json = await res.json();
  renderList(json);
}
function renderList(json) {
  const tbody = document.getElementById('convBody');
  // Team colors
  const teamColors = {
    'red':   { bg:'#ffebee', color:'#c0392b', border:'#e74c3c', label:'红' },
    'blue':  { bg:'#e3f2fd', color:'#2471a3', border:'#3498db', label:'蓝' },
    'green': { bg:'#e8f5e9', color:'#1e7e34', border:'#27ae60', label:'绿' },
  };
  function teamBadge(team) {
    const t = teamColors[team] || { bg:'#f5f5f5', color:'#666', border:'#999', label:team };
    return `<span style="display:inline-block;padding:0 4px;border-radius:2px;font-size:9px;font-weight:600;background:${t.bg};color:${t.color};border:1px solid ${t.border};margin:1px;">${t.label}</span>`;
  }
  tbody.innerHTML = json.data.map(c => {
    const time = new Date(c.started_at).toLocaleString('zh-CN');
    const title = c.title || c.session_id?.slice(0, 16) || '(无标题)';

    // Skill badges
    let skillStr = '';
    if (c.skills && c.skills.length > 0) {
      skillStr = c.skills.map(s =>
        '<span class="badge badge-skill">' + esc(s.skill_name || s.name) + '</span>'
      ).join(' ');
    }

    // Agent badges with team colors
    let agentStr = '<span style="color:#999;font-size:11px;">-</span>';
    if (c.agents) {
      const agentList = c.agents.split(',');
      const teams = c.agentTeams || [];
      agentStr = agentList.map((a, i) => {
        const t = teams[i] || '';
        const tc = teamBadge(t);
        return '<span class="badge badge-a2a" style="font-size:10px;">' + tc + ' ' + esc(a.trim().slice(0, 20)) + '</span>';
      }).join(' ');
    }

    // Models used (show all, not just latest)
    let modelStr = '<span style="color:#999;font-size:11px;">-</span>';
    if (c.models_used && c.models_used.length > 0) {
      modelStr = c.models_used.map(m => {
        const short = m.replace('deepseek-v4-', '').replace('deepseek-', '');
        return '<span class="badge" style="background:#e8eaf6;color:#283593;font-size:10px;">' + esc(short) + '</span>';
      }).join(' ');
    } else if (c.model) {
      const short = c.model.replace('deepseek-v4-', '').replace('deepseek-', '');
      modelStr = '<span class="badge" style="background:#e8eaf6;color:#283593;font-size:10px;">' + esc(short) + '</span>';
    }

    // Message counts
    const userMsgCount = c.msg_breakdown?.user?.msg_count || 0;
    const a2aCount = c.msg_breakdown?.a2a?.msg_count || 0;

    // Token breakdown from conversation totals (accurate PATCH values)
    const totalIn = c.total_input_tokens || 0;
    const totalOut = c.total_output_tokens || 0;
    const totalCost = c.total_cost || 0;
    const contextMax = c.context_max || 0;

    // Peak single-call input (capped at model max context)
    const peakUser = c.msg_breakdown?.user?.peak_input || 0;
    const peakA2a = c.msg_breakdown?.a2a?.peak_input || 0;
    const peakInput = Math.max(peakUser, peakA2a);
    function peakBadge(peak) {
      if (!peak) return '<span style="color:#999;font-size:11px;">-</span>';
      return '<span style="font-weight:600;font-size:12px;">' + peak.toLocaleString() + '</span>';
    }
    const baselineCost = c.total_baseline_cost || 0;

    // Cache from msg_breakdown (best available)
    const userCache = c.msg_breakdown?.user?.cached_input || 0;
    const a2aCache = c.msg_breakdown?.a2a?.cached_input || 0;
    const totalCache = userCache + a2aCache;
    const userUncached = c.msg_breakdown?.user?.uncached_input || 0;
    const a2aUncached = c.msg_breakdown?.a2a?.uncached_input || 0;
    const totalUncached = userUncached + a2aUncached;

    // Content preview
    const preview = c.last_user_message ? esc(c.last_user_message.slice(0, 80)) + (c.last_user_message.length > 80 ? '...' : '') : '<span style="color:#999;font-size:11px;">-</span>';

    return '<tr onclick="location=\'/conversations/' + c.id + '\'" style="cursor:pointer">' +
      '<td><strong>' + esc(title) + '</strong></td>' +
      '<td>' + modelStr + '</td>' +
      '<td><span class="badge badge-user">' + userMsgCount + '</span> <span class="badge badge-a2a">' + a2aCount + '</span></td>' +
      '<td><span style="color:#2e7d32;">' + totalCache.toLocaleString() + '</span> / <span style="color:#1565c0;">' + totalUncached.toLocaleString() + '</span></td>' +
      '<td>' + totalOut.toLocaleString() + '</td>' +
      '<td>' + peakBadge(peakInput) + '</td>' +
      '<td class="cost-pos">' + (totalCost > 0 ? '¥' + totalCost.toFixed(4) : '-') + '</td>' +
      '<td class="cost-save">' + (baselineCost > 0 ? '¥' + (baselineCost - totalCost).toFixed(4) + ' (' + ((baselineCost - totalCost) / baselineCost * 100).toFixed(1) + '%)' : '-') + '</td>' +
      '<td>' + agentStr + '</td>' +
      '<td>' + (c.skills && c.skills.length > 0 ? skillStr : '<span style="color:#999;font-size:11px;">-</span>') + '</td>' +
      '<td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px;color:#555;" title="' + esc(c.last_user_message) + '">' + preview + '</td>' +
      '<td>' + time + '</td>' +
      '</tr>';
  }).join('');
  document.getElementById('totalCount').textContent = json.total;
  renderPagination(json);
}
function renderPagination(json) {
  const totalPages = Math.ceil(json.total / json.limit);
  const el = document.getElementById('pagination');
  var html = '<button onclick="goPage(' + (json.page - 1) + ')" ' + (json.page <= 1 ? 'disabled' : '') + '>上一页</button>';
  html += '<span>' + json.page + ' / ' + (totalPages || 1) + '</span>';
  html += '<button onclick="goPage(' + (json.page + 1) + ')" ' + (json.page >= totalPages ? 'disabled' : '') + '>下一页</button>';
  el.innerHTML = html;
}
function goPage(p) { page = p; loadList(); }
function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
loadList();
</script>
