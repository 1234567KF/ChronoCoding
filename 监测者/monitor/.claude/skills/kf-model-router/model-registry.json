{
  "schemaVersion": "1.1",
  "description": "Multivendor model registry for kf-model-router. Configuration-driven, zero code changes to register new models.",
  "providers": [
    {
      "id": "deepseek",
      "name": "DeepSeek",
      "baseUrl": "https://api.deepseek.com/v1",
      "envKey": "DEEPSEEK_API_KEY",
      "healthEndpoint": "/models",
      "adapter": "deepseek",
      "adapterPath": "skills/kf-smart-router/providers/",
      "rateLimit": {
        "capacity": 16,
        "fillRate": 0.26,
        "maxQueueTime": 5000,
        "refillInterval": 1000
      },
      "models": [
        {
          "id": "deepseek-v4-pro",
          "family": "pro",
          "description": "DeepSeek v4 Pro — heavy reasoning",
          "capabilities": ["deep-reasoning", "complex-code", "architecture", "planning", "bug-debug"],
          "costPer1KInput": 3.0,
          "costPer1KOutput": 15.0,
          "cacheHitCostPer1KInput": 0.025,
          "supportsCache": true,
          "priority": 1,
          "defaultFor": ["architecture", "bug-debug", "planning"],
          "providerModelId": "deepseek-v4-pro"
        },
        {
          "id": "deepseek-v4-flash",
          "family": "flash",
          "description": "DeepSeek v4 Flash — fast execution",
          "capabilities": ["code", "review", "qa", "docs", "chat", "testing", "ui-prototype", "simple-qa"],
          "costPer1KInput": 1.0,
          "costPer1KOutput": 5.0,
          "cacheHitCostPer1KInput": 0.02,
          "supportsCache": true,
          "priority": 10,
          "defaultFor": ["coding", "review", "testing", "docs", "ui-prototype", "simple-qa"],
          "providerModelId": "deepseek-v4-flash"
        }
      ]
    },
    {
      "id": "minimax",
      "name": "MiniMax",
      "baseUrl": "https://api.minimax.chat/v1",
      "envKey": "MINIMAX_API_KEY",
      "healthEndpoint": "/models",
      "adapter": "minimax",
      "adapterPath": "skills/kf-smart-router/providers/",
      "rateLimit": {
        "capacity": 24,
        "fillRate": 0.4,
        "maxQueueTime": 5000,
        "refillInterval": 1000
      },
      "models": [
        {
          "id": "minimax-2.7",
          "family": "pro",
          "description": "MiniMax 2.7 — general purpose",
          "capabilities": ["deep-reasoning", "code", "chat", "review", "testing", "docs", "planning", "architecture"],
          "costPer1KInput": 1.0,
          "costPer1KOutput": 5.0,
          "cacheHitCostPer1KInput": null,
          "supportsCache": false,
          "priority": 10,
          "defaultFor": ["docs", "ui-prototype"],
          "providerModelId": "minimax-2.7"
        }
      ]
    },
    {
      "id": "openai",
      "name": "OpenAI",
      "baseUrl": "https://api.openai.com/v1",
      "envKey": "OPENAI_API_KEY",
      "healthEndpoint": "/models",
      "adapter": "openai",
      "adapterPath": "skills/kf-smart-router/providers/",
      "rateLimit": {
        "capacity": 16,
        "fillRate": 0.26,
        "maxQueueTime": 5000,
        "refillInterval": 1000
      },
      "models": [
        {
          "id": "openai-o3",
          "family": "reasoning",
          "description": "OpenAI o3 — highest reasoning capability",
          "capabilities": ["deep-reasoning", "complex-code", "architecture"],
          "costPer1KInput": 10.0,
          "costPer1KOutput": 40.0,
          "cacheHitCostPer1KInput": null,
          "supportsCache": false,
          "priority": 0,
          "defaultFor": [],
          "providerModelId": "o3"
        },
        {
          "id": "openai-4o-mini",
          "family": "fast",
          "description": "OpenAI 4o-mini — low-cost fast responses",
          "capabilities": ["code", "chat", "docs", "review", "testing", "simple-qa"],
          "costPer1KInput": 0.15,
          "costPer1KOutput": 0.6,
          "cacheHitCostPer1KInput": null,
          "supportsCache": false,
          "priority": 12,
          "defaultFor": ["simple-qa", "formatting"],
          "providerModelId": "gpt-4o-mini"
        }
      ]
    }
  ],
  "routingFallback": {
    "strategy": "cost-first",
    "defaultProvider": "deepseek",
    "defaultModel": "deepseek-v4-flash"
  },
  "compatMappings": {
    "pro": "deepseek-v4-pro",
    "flash": "deepseek-v4-flash",
    "sonnet": "deepseek-v4-flash",
    "opus": "deepseek-v4-pro"
  }
}
