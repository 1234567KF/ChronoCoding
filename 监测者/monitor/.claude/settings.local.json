{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "sk-d1f346cb32b043bf9f77c5c0c72e3d59",
    "ANTHROPIC_BASE_URL": "https://api.deepseek.com/anthropic",
    "CLAUDE_CODE_ALWAYS_THINKING": "1",
