      "Bash(rmdir skills *)",
      "Skill(update-config)",
      "Bash(npm update *)",
      "Bash(npm install *)",
      "Bash(npm search *)",
      "Bash(claude *)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(gh repo *)",
      "Bash(git remote *)",
      "Bash(git push *)",
      "Bash(git clone *)",
      "Bash(git fetch *)",
      "Bash(git ls-tree *)",
      "Bash(git checkout *)",
      "mcp__ruflo__memory_bridge_status",
      "mcp__ruflo__config_list",
      "mcp__ruflo__memory_import_claude",
      "mcp__ruflo__memory_search_unified",
      "Bash(git config *)",
      "Bash(git merge *)",
      "Bash(git cherry-pick *)",
      "Bash(git branch *)",
      "Bash(dir \"D:\\\\projects\\\\AI횄짠횂쩌횂혯횄짠횂짢횂혢횄짝횂혲횂쨘횄짤횂짤횂쩐\\\\.swarm\\\\\")",
      "Bash(git --version)",
      "Bash(claude-flow --version)",
      "Bash(npm list *)",
      "Bash(npm root *)",
      "Bash(node .claude/helpers/cost-tracker.cjs *)",
      "Bash(npx -y ruflo@latest --version)",
      "Bash(echo \"Git: $\\(git --version)",
      "Bash(mv qoder *)",
      "Bash(mv prd-generator *)",
      "Bash(mv triple-collaboration *)",
      "Bash(mv ui-prototype-generator *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|bash",
        "hooks": [
          {
            "type": "command",
            "command": "lean-ctx hook rewrite"
          }
        ]
      },
      {
        "matcher": "Read|read|ReadFile|read_file|View|view|Grep|grep|Search|search|ListFiles|list_files|ListDirectory|list_directory",
        "hooks": [
          {
            "type": "command",
            "command": "lean-ctx hook redirect"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/helpers/cost-tracker.cjs --update",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "outputStyle": "stream",
  "viewMode": "verbose",
  "alwaysThinkingEnabled": true,
  "showThinkingSummaries": true,
  "theme": "dark",
  "verbose": true,
  "autoScrollEnabled": true,
  "showTurnDuration": true,
  "showMessageTimestamps": true,
  "terminalProgressBarEnabled": true,
  "model": "deepseek-v4-pro"
}
