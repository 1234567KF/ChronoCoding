#!/bin/bash
# pre-commit hook
# 路径: ~/.claude-flow/hooks/pre-commit（全局）或 .git/hooks/pre-commit（项目级）
# 使用方式: 将此文件复制到 .git/hooks/pre-commit 并添加执行权限

echo "Running pre-commit checks..."

# 格式化代码
echo "[1/3] Formatting code..."
npm run format 2>/dev/null || true

# Lint 检查
echo "[2/3] Running lint..."
npm run lint 2>/dev/null || true

# 运行测试
echo "[3/3] Running tests..."
npm test -- --coverage 2>/dev/null || true

echo "Pre-commit complete"
